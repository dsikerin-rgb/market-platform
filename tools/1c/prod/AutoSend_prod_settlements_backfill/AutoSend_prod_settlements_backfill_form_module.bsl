КонецФункции

&НаСервере
Функция НайтиОрганизациюВыгрузки(ИНН, Наименование)
    Запрос = Новый Запрос;
    Запрос.Текст =
    "ВЫБРАТЬ ПЕРВЫЕ 1
    |   Организации.Ссылка КАК Ссылка
    |ИЗ
    |   Справочник.Организации КАК Организации
    |ГДЕ
    |   НЕ Организации.ПометкаУдаления
    |   И (
    |       Организации.ИНН = &ИНН
    |       ИЛИ Организации.Наименование = &Наименование
    |   )";

    Запрос.УстановитьПараметр("ИНН", ИНН);
    Запрос.УстановитьПараметр("Наименование", Наименование);

    Выборка = Запрос.Выполнить().Выбрать();
    Если Выборка.Следующий() Тогда
        Возврат Выборка.Ссылка;
    КонецЕсли;

    Возврат Справочники.Организации.ПустаяСсылка();
КонецФункции

&НаСервере
Функция ПолучитьОрганизацииВыгрузки()
    Результат = Новый Массив;

    ОрганизацияФриц = НайтиОрганизациюВыгрузки("222509471501", "ИП Фриц А. Г.");
    Если НЕ ОрганизацияФриц.Пустая() Тогда
        Результат.Добавить(ОрганизацияФриц);
    КонецЕсли;

    ОрганизацияЭЯ = НайтиОрганизациюВыгрузки("2222904071", "ООО ""ЭКО ЯРМАРКА""");
    Если НЕ ОрганизацияЭЯ.Пустая() Тогда
        Результат.Добавить(ОрганизацияЭЯ);
    КонецЕсли;

    Возврат Результат;
КонецФункции

&НаСервере
Функция ЕстьОрганизацииВыгрузки(ОрганизацииВыгрузки)
    Возврат ОрганизацииВыгрузки.Количество() = 2;
КонецФункции

&НаСервере
Процедура ДобавитьФильтрПоОрганизациям(Запрос, ОрганизацииВыгрузки)
    Запрос.УстановитьПараметр("ОрганизацииВыгрузки", ОрганизацииВыгрузки);
КонецПроцедуры

&НаСервере
Функция ЕстьГруппыАрендаторов(Группы)
    Возврат НЕ Группы.Фриц.Пустая() Или НЕ Группы.ЭЯ.Пустая();
КонецФункции

&НаСервере
Процедура ДобавитьФильтрПоГруппам(Запрос, Группы)
    Если НЕ Группы.Фриц.Пустая() Тогда
        Запрос.УстановитьПараметр("ГруппаАрендаторыФриц", Группы.Фриц);
    КонецЕсли;

    Если НЕ Группы.ЭЯ.Пустая() Тогда
        Запрос.УстановитьПараметр("ГруппаАрендаторыЭЯ", Группы.ЭЯ);
    КонецЕсли;
КонецПроцедуры

&НаСервере
Функция ПостроитьУсловиеПоГруппам(Группы, ИмяПоля)
    Если НЕ Группы.Фриц.Пустая() И НЕ Группы.ЭЯ.Пустая() Тогда
        Возврат
        "
        |   И (
        |       " + ИмяПоля + " В ИЕРАРХИИ(&ГруппаАрендаторыФриц)
        |       ИЛИ " + ИмяПоля + " В ИЕРАРХИИ(&ГруппаАрендаторыЭЯ)
        |   )";
    ИначеЕсли НЕ Группы.Фриц.Пустая() Тогда
        Возврат
        "
        |   И " + ИмяПоля + " В ИЕРАРХИИ(&ГруппаАрендаторыФриц)";
    Иначе
        Возврат
        "
        |   И " + ИмяПоля + " В ИЕРАРХИИ(&ГруппаАрендаторыЭЯ)";
    КонецЕсли;
КонецФункции

&НаСервере
Функция ДатаНачалаМесяцаИзСтроки(ПериодСтрокой)
    Возврат Дата(Число(Лев(ПериодСтрокой, 4)), Число(Прав(ПериодСтрокой, 2)), 1);
КонецФункции

&НаСервере
Функция ФорматДатаВремяДляAPI(ДатаЗначение)
    Возврат
        Формат(Год(ДатаЗначение), "ЧГ=4") + "-" +
        Прав("0" + Строка(Месяц(ДатаЗначение)), 2) + "-" +
        Прав("0" + Строка(День(ДатаЗначение)), 2) + " " +
        Прав("0" + Строка(Час(ДатаЗначение)), 2) + ":" +
        Прав("0" + Строка(Минута(ДатаЗначение)), 2) + ":" +
        Прав("0" + Строка(Секунда(ДатаЗначение)), 2);
КонецФункции

&НаСервере
Функция ФорматДатаДляAPI(ДатаЗначение)
    Возврат
        Формат(Год(ДатаЗначение), "ЧГ=4") + "-" +
        Прав("0" + Строка(Месяц(ДатаЗначение)), 2) + "-" +
        Прав("0" + Строка(День(ДатаЗначение)), 2);
КонецФункции

&НаСервере
Функция ОбрезатьСтроку(ЗначениеСтрокой, Максимум)
    Стр = СокрЛП(Строка(ЗначениеСтрокой));
    Если СтрДлина(Стр) <= Максимум Тогда
        Возврат Стр;
    КонецЕсли;
    Возврат Лев(Стр, Максимум);
КонецФункции

&НаСервере
Функция СформироватьJSON(Пэйлоад)
    ЗаписьJSON = Новый ЗаписьJSON;
    ЗаписьJSON.УстановитьСтроку();
    ЗаписатьJSON(ЗаписьJSON, Пэйлоад);
    Возврат ЗаписьJSON.Закрыть();
КонецФункции

&НаСервере
Функция ОтправитьJSONНаСервер(Путь, СтрокаJSON, Хост, Порт, Токен)
    Заголовки = Новый Соответствие;
    Заголовки.Вставить("Content-Type", "application/json");
    Заголовки.Вставить("Authorization", "Bearer " + Токен);
    Заголовки.Вставить("Accept", "application/json");

    HTTPЗапрос = Новый HTTPЗапрос(Путь, Заголовки);
    HTTPЗапрос.УстановитьТелоИзСтроки(СтрокаJSON, КодировкаТекста.UTF8);

    СоединениеHTTP = Новый HTTPСоединение(
        Хост, Порт, , , , 30,
        Новый ЗащищенноеСоединениеOpenSSL()
    );

    Попытка
        Ответ = СоединениеHTTP.ОтправитьДляОбработки(HTTPЗапрос);
        Возврат "Код: " + Ответ.КодСостояния + " | Ответ: " + Ответ.ПолучитьТелоКакСтроку();
    Исключение
        Возврат "Ошибка HTTP: " + ОписаниеОшибки();
    КонецПопытки;
КонецФункции

&НаСервере
Функция ВыгрузитьРасчетыНаСервере(ПериодСтрокой, СчетСтрокой)
    ПараметрыПодключения = ПолучитьПараметрыПодключения();

    СчетСтрокой = СокрЛП(Строка(СчетСтрокой));
    СчетУчета = ПланыСчетов.Хозрасчетный.НайтиПоКоду(СчетСтрокой);
    Если СчетУчета.Пустая() Тогда
        Рез = Новый Структура;
        Рез.Вставить("json", "");
        Рез.Вставить("result", "Не найден счет учета: " + СчетСтрокой);
        Возврат Рез;
    КонецЕсли;

    НачалоПериода = ДатаНачалаМесяцаИзСтроки(ПериодСтрокой);
    КонецПериода = КонецМесяца(НачалоПериода);
    ТД = ТекущаяДата();

    Группы = ПолучитьГруппыАрендаторов();
    Если НЕ ЕстьГруппыАрендаторов(Группы) Тогда
        Рез = Новый Структура;
        Рез.Вставить("json", "");
        Рез.Вставить("result", "Не найдены группы контрагентов: АРЕНДАТОРЫ ФРИЦ / АРЕНДАТОРЫ ЭЯ");
        Возврат Рез;
    КонецЕсли;

    ОрганизацииВыгрузки = ПолучитьОрганизацииВыгрузки();
    Если НЕ ЕстьОрганизацииВыгрузки(ОрганизацииВыгрузки) Тогда
        Рез = Новый Структура;
        Рез.Вставить("json", "");
        Рез.Вставить("result", "Не найдены организации выгрузки: ИП Фриц А. Г. / ООО ""ЭКО ЯРМАРКА""");
        Возврат Рез;
    КонецЕсли;

    ТекстЗапроса =
    "ВЫБРАТЬ
    |   Остатки.Счет КАК Счет,
    |   Остатки.Организация КАК Организация,
    |   Остатки.Субконто1 КАК Контрагент,
    |   Остатки.Субконто2 КАК Договор,
    |   Остатки.Субконто3 КАК ДокументРасчетов,
    |   Остатки.СуммаНачальныйОстатокДт КАК НачальныйДебет,
    |   Остатки.СуммаНачальныйОстатокКт КАК НачальныйКредит,
    |   Остатки.СуммаОборотДт КАК ОборотДебет,
    |   Остатки.СуммаОборотКт КАК ОборотКредит,
    |   Остатки.СуммаКонечныйОстатокДт КАК КонечныйДебет,
    |   Остатки.СуммаКонечныйОстатокКт КАК КонечныйКредит
    |ИЗ
    |   РегистрБухгалтерии.Хозрасчетный.ОстаткиИОбороты(
    |       &НачалоПериода, &КонецПериода, , ,
    |       Счет В ИЕРАРХИИ (&СчетУчета)
    |   ) КАК Остатки
    |ГДЕ
    |   Остатки.Субконто1 <> ЗНАЧЕНИЕ(Справочник.Контрагенты.ПустаяСсылка)
    |   И Остатки.Субконто2 <> ЗНАЧЕНИЕ(Справочник.ДоговорыКонтрагентов.ПустаяСсылка)
    |   И Остатки.Организация В (&ОрганизацииВыгрузки)
    |   И (
    |       Остатки.СуммаНачальныйОстатокДт <> 0
    |       ИЛИ Остатки.СуммаНачальныйОстатокКт <> 0
    |       ИЛИ Остатки.СуммаОборотДт <> 0
    |       ИЛИ Остатки.СуммаОборотКт <> 0
    |       ИЛИ Остатки.СуммаКонечныйОстатокДт <> 0
    |       ИЛИ Остатки.СуммаКонечныйОстатокКт <> 0
    |   )";

    ТекстЗапроса = ТекстЗапроса + ПостроитьУсловиеПоГруппам(Группы, "Остатки.Субконто1");

    Запрос = Новый Запрос;
    Запрос.Текст = ТекстЗапроса;
    Запрос.УстановитьПараметр("НачалоПериода", НачалоПериода);
    Запрос.УстановитьПараметр("КонецПериода", КонецПериода);
    Запрос.УстановитьПараметр("СчетУчета", СчетУчета);
    ДобавитьФильтрПоГруппам(Запрос, Группы);
    ДобавитьФильтрПоОрганизациям(Запрос, ОрганизацииВыгрузки);

    Выборка = Запрос.Выполнить().Выбрать();
    МассивItems = Новый Массив;

    Пока Выборка.Следующий() Цикл
        Если Выборка.Контрагент.Пустая() Или Выборка.Договор.Пустая() Тогда
            Продолжить;
        КонецЕсли;

        Элемент = Новый Структура;
        Элемент.Вставить("tenant_external_id", Строка(Выборка.Контрагент.УникальныйИдентификатор()));
        Элемент.Вставить("tenant_name", ОбрезатьСтроку(Выборка.Контрагент.Наименование, 255));
        Элемент.Вставить("contract_external_id", Строка(Выборка.Договор.УникальныйИдентификатор()));
        Элемент.Вставить("contract_name", ОбрезатьСтроку(Выборка.Договор.Наименование, 255));
        Элемент.Вставить("account", СчетСтрокой);
        Элемент.Вставить("opening_debit", Выборка.НачальныйДебет);
        Элемент.Вставить("opening_credit", Выборка.НачальныйКредит);
        Элемент.Вставить("turnover_debit", Выборка.ОборотДебет);
        Элемент.Вставить("turnover_credit", Выборка.ОборотКредит);
        Элемент.Вставить("closing_debit", Выборка.КонечныйДебет);
        Элемент.Вставить("closing_credit", Выборка.КонечныйКредит);
        Элемент.Вставить("currency", "RUB");
        Элемент.Вставить("organization_external_id", Строка(Выборка.Организация.УникальныйИдентификатор()));
        Элемент.Вставить("organization_name", ОбрезатьСтроку(Выборка.Организация.Наименование, 255));

        Если НЕ Выборка.ДокументРасчетов.Пустая() Тогда
            Элемент.Вставить("settlement_document_external_id", Строка(Выборка.ДокументРасчетов.УникальныйИдентификатор()));
            Элемент.Вставить("settlement_document_name", ОбрезатьСтроку(Выборка.ДокументРасчетов, 500));
        КонецЕсли;

        МассивItems.Добавить(Элемент);
    КонецЦикла;

    Если МассивItems.Количество() = 0 Тогда
        Рез = Новый Структура;
        Рез.Вставить("json", "");
        Рез.Вставить("result", "Нет данных за период " + ПериодСтрокой + " по счету " + СчетСтрокой);
        Возврат Рез;
    КонецЕсли;

    Payload = Новый Структура;
    Payload.Вставить("calculated_at", ФорматДатаВремяДляAPI(ТД));
    Payload.Вставить("period_from", ФорматДатаДляAPI(НачалоПериода));
    Payload.Вставить("period_to", ФорматДатаДляAPI(КонецПериода));
    Payload.Вставить("account", СчетСтрокой);
    Payload.Вставить("items", МассивItems);

    СтрокаJSON = СформироватьJSON(Payload);
    РезультатТекст = ОтправитьJSONНаСервер(
        "/api/1c/settlements",
        СтрокаJSON,
        ПараметрыПодключения.Хост,
        ПараметрыПодключения.Порт,
        ПараметрыПодключения.Токен
    );

    Рез = Новый Структура;
    Рез.Вставить("json", СтрокаJSON);
    Рез.Вставить("result", РезультатТекст);
    Возврат Рез;
КонецФункции
