&НаКлиенте
Перем ИмяФайлаЛога;

&НаКлиенте
Функция ПолучитьПараметрЗапуска() Экспорт
    Параметр = "";
    Попытка
        Параметр = Строка(ПараметрЗапуска);
    Исключение
        Параметр = "";
    КонецПопытки;
    Возврат СокрЛП(Параметр);
КонецФункции

&НаКлиенте
Функция ПолучитьЧастиПараметраЗапуска() Экспорт
    Параметр = ПолучитьПараметрЗапуска();
    Если ПустаяСтрока(Параметр) Тогда
        Возврат Новый Массив;
    КонецЕсли;

    Части = СтрРазделить(Параметр, ";");
    Результат = Новый Массив;
    Для Каждого Часть Из Части Цикл
        Результат.Добавить(СокрЛП(Строка(Часть)));
    КонецЦикла;

    Возврат Результат;
КонецФункции

&НаКлиенте
Функция ЭтоАвтоЗапуск() Экспорт
    Части = ПолучитьЧастиПараметраЗапуска();
    Если Части.Количество() < 2 Тогда
        Возврат Ложь;
    КонецЕсли;

    Возврат ВРег(Части[0]) = "AUTO" И ВРег(Части[1]) = "SETTLEMENTS";
КонецФункции

&НаКлиенте
Функция ЭтоКорректныйПериод(ПериодСтрокой) Экспорт
    ПериодСтрокой = СокрЛП(Строка(ПериодСтрокой));
    Если СтрДлина(ПериодСтрокой) <> 7 Тогда
        Возврат Ложь;
    КонецЕсли;
    Если Сред(ПериодСтрокой, 5, 1) <> "-" Тогда
        Возврат Ложь;
    КонецЕсли;

    ГодСтрокой = Лев(ПериодСтрокой, 4);
    МесяцСтрокой = Прав(ПериодСтрокой, 2);
    Для Индекс = 1 По 4 Цикл
        Если СтрНайти("0123456789", Сред(ГодСтрокой, Индекс, 1)) = 0 Тогда
            Возврат Ложь;
        КонецЕсли;
    КонецЦикла;
    Для Индекс = 1 По 2 Цикл
        Если СтрНайти("0123456789", Сред(МесяцСтрокой, Индекс, 1)) = 0 Тогда
            Возврат Ложь;
        КонецЕсли;
    КонецЦикла;

    МесяцЧислом = Число(МесяцСтрокой);
    Возврат МесяцЧислом >= 1 И МесяцЧислом <= 12;
КонецФункции

&НаКлиенте
Процедура ПриОткрытии(Отказ)
    Если ИмяФайлаЛога = Неопределено Или ПустаяСтрока(ИмяФайлаЛога) Тогда
        ИмяФайлаЛога = КаталогВременныхФайлов() + "autosend_prod_settlements_backfill.log";
    КонецЕсли;

    ЗаписатьВФайл("STARTUP_PARAMETER: [" + ПолучитьПараметрЗапуска() + "]");

    Если НЕ ЭтоАвтоЗапуск() Тогда
        Сообщить("Запустите обработку с параметром AUTO;SETTLEMENTS;YYYY-MM;ACCOUNT");
        Возврат;
    КонецЕсли;

    Части = ПолучитьЧастиПараметраЗапуска();
    Если Части.Количество() < 4 Тогда
        ЗаписатьВФайл("ERROR: expected AUTO;SETTLEMENTS;YYYY-MM;ACCOUNT");
        ЗавершитьРаботуСистемы(Ложь);
        Возврат;
    КонецЕсли;

    ПериодСтрокой = Части[2];
    СчетСтрокой = Части[3];

    Если НЕ ЭтоКорректныйПериод(ПериодСтрокой) Тогда
        ЗаписатьВФайл("ERROR: invalid period [" + ПериодСтрокой + "]");
        ЗавершитьРаботуСистемы(Ложь);
        Возврат;
    КонецЕсли;

    Результат = ВыгрузитьРасчетыНаСервере(ПериодСтрокой, СчетСтрокой);
    ЗаписатьРезультатВыгрузки("SETTLEMENTS", Результат);

    ЗавершитьРаботуСистемы(Ложь);
КонецПроцедуры

&НаКлиенте
Процедура ЗаписатьРезультатВыгрузки(ИмяОперации, Результат)
    Попытка
        ЗаписатьВФайл(ИмяОперации + " RESULT: " + Результат.result);
        Если Результат.Свойство("json") И НЕ ПустаяСтрока(Результат.json) Тогда
            ЗаписатьВФайл(ИмяОперации + " JSON: " + Результат.json);
        КонецЕсли;
    Исключение
        ЗаписатьВФайл(ИмяОперации + " LOG_ERROR: " + ОписаниеОшибки());
    КонецПопытки;
КонецПроцедуры

&НаКлиенте
Процедура ЗаписатьВФайл(Текст)
    Попытка
        Файл = Новый ЗаписьТекста(ИмяФайлаЛога, КодировкаТекста.UTF8);
        Файл.ЗаписатьСтроку(Формат(ТекущаяДата(), "ДФ=yyyy-MM-dd HH:mm:ss") + " " + Текст);
        Файл.Закрыть();
    Исключение
    КонецПопытки;
КонецПроцедуры

