APP_NAME="Market Platform"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_TIMEZONE=UTC
APP_URL=http://localhost

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

# ----------------------------
# Database
# ----------------------------
# PostgreSQL (local/staging/production)
DB_CONNECTION=pgsql
DB_HOST=127.0.0.1
DB_PORT=5432
DB_DATABASE=market_platform
DB_USERNAME=market_platform
DB_PASSWORD=

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

# ----------------------------
# SaaS / Market context safety flags
# ----------------------------
# Keep all enforcement flags off until local/staging checks are complete.
MARKET_CONTEXT_SCOPE_ENABLED=false
MARKET_CONTEXT_WRITE_GUARDS_ENABLED=false
MARKET_CONTEXT_STRICT_MISSING=false
MARKET_CONTEXT_SHADOW_MODE=true
MARKET_CONTEXT_SUPER_ADMIN_FALLBACK=none

# ----------------------------
# Demo / pilot contour safety flags
# ----------------------------
# Keep disabled until a reviewed demo provisioning package is ready.
DEMO_PILOT_ENABLED=false
DEMO_PILOT_PROVISION_ENABLED=false
DEMO_PILOT_RESET_ENABLED=false
DEMO_PILOT_ALLOW_PROD_WRITES=false
DEMO_PILOT_MARKET_SLUG=demo-market
DEMO_PILOT_EMAIL_DOMAIN=demo.marketuchet.local
DEMO_PILOT_EXTERNAL_INTEGRATIONS_ENABLED=false

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local

# ----------------------------
# Queue / Cache
# ----------------------------
# Local default (simple)
QUEUE_CONNECTION=database
CACHE_STORE=database

# Staging/Production recommended (Redis)
# QUEUE_CONNECTION=redis
# CACHE_STORE=redis

CACHE_PREFIX=

MEMCACHED_HOST=127.0.0.1

# ----------------------------
# Redis
# ----------------------------
REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

# Optional: separate queue connection/name
# REDIS_QUEUE_CONNECTION=default
# REDIS_QUEUE=default
# REDIS_QUEUE_RETRY_AFTER=90

# ----------------------------
# Horizon (Queue dashboard) - planned
# ----------------------------
# HORIZON_PREFIX=market_platform:
# HORIZON_DOMAIN=null
# HORIZON_PATH=horizon

# ----------------------------
# Telescope (debug dashboard) - planned
# ----------------------------
TELESCOPE_ENABLED=false

MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_URL=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"
MAIL_EHLO_DOMAIN=null
MAIL_LOG_CHANNEL=null

# Telegram notifications (disabled by default)
TELEGRAM_ENABLED=false
TELEGRAM_BOT_TOKEN=
TELEGRAM_BOT_USERNAME=
TELEGRAM_WEBHOOK_SECRET=
TELEGRAM_API_BASE=https://api.telegram.org
TELEGRAM_HTTP_TIMEOUT=10
TELEGRAM_API_CONNECT_TO_IPS=

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

# Market documents storage. Use "s3" in production when AWS/S3-compatible storage is configured.
MARKET_DOCUMENTS_DISK=public
MARKET_DOCUMENTS_DIRECTORY=market-documents

VITE_APP_NAME="${APP_NAME}"
